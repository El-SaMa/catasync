RABBITMQ_URL=amqp://user:pass@host:5672/catasync
QUEUES=catasyncimportexecute
PREFETCH=1
WP_CALLBACK_URL=https://your-wp-site.com/wp-admin/admin-ajax.php?action=catasync_offload_callback
WP_STATUS_URL=https://your-wp-site.com/wp-admin/admin-ajax.php?action=catasync_worker_status_ping
STATUS_PING_INTERVAL_MS=5000
STATUS_PING_TIMEOUT_MS=30000
WP_BIN=wp
WP_PATH=/var/www/html
IMPORT_TIMEOUT_MS=1200000
CALLBACK_TIMEOUT_MS=30000
CALLBACK_MAX_ATTEMPTS=3
RECONNECT_DELAY_MS=5000
WORKER_SECRET=changeme
WORKER_NAME=worker-1.example.com
OPENAI_API_KEY=
OPENAI_MODEL=
